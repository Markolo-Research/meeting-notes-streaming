#!/usr/bin/env -S uv run python
from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
import tempfile
from collections import Counter
from dataclasses import dataclass
from pathlib import Path
from typing import cast

ROOT_DIR = Path(__file__).resolve().parents[2]
BASELINE_PATH = ROOT_DIR / "scripts/guards/python-slop-baseline.json"
RUFF_RULES = "BLE,C901,PLR0911,PLR0912,PLR0913,PLR0915,FBT001,FBT002"


@dataclass(frozen=True)
class SlopMetrics:
    ruff_strict: dict[str, object]
    vulture: dict[str, int]
    jscpd: dict[str, int | float] | None = None

    def to_json_dict(self) -> dict[str, object]:
        payload: dict[str, object] = {
            "ruff_strict": self.ruff_strict,
            "vulture": self.vulture,
        }
        if self.jscpd is not None:
            payload["jscpd"] = self.jscpd
        return payload


def run_command(
    args: list[str], *, root_dir: Path = ROOT_DIR, stdout_path: Path | None = None
) -> subprocess.CompletedProcess[str]:
    stdout_handle = stdout_path.open("w", encoding="utf-8") if stdout_path else subprocess.PIPE
    try:
        return subprocess.run(
            args,
            cwd=root_dir,
            check=False,
            text=True,
            stdout=stdout_handle,
            stderr=subprocess.PIPE,
        )
    finally:
        if stdout_path:
            stdout_handle.close()


def scan_ruff(tmpdir: Path, *, root_dir: Path) -> dict[str, object]:
    output_path = tmpdir / "ruff-strict.json"
    result = run_command(
        [
            "uv",
            "run",
            "ruff",
            "check",
            "--select",
            RUFF_RULES,
            "--exit-zero",
            "--output-format",
            "json",
            ".",
        ],
        root_dir=root_dir,
        stdout_path=output_path,
    )
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        raise SystemExit(result.returncode)

    findings = json.loads(output_path.read_text(encoding="utf-8"))
    by_rule = Counter(str(finding["code"]) for finding in findings)
    return {"total": sum(by_rule.values()), "by_rule": dict(sorted(by_rule.items()))}


def tracked_python_paths(*, root_dir: Path) -> list[str]:
    result = subprocess.run(
        ["git", "ls-files", "*.py"],
        cwd=root_dir,
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        raise SystemExit(result.returncode)
    return [line for line in result.stdout.splitlines() if line.strip()]


def has_vulture_config(*, root_dir: Path) -> bool:
    import tomllib

    pyproject_path = root_dir / "pyproject.toml"
    if not pyproject_path.exists():
        return False
    with pyproject_path.open("rb") as handle:
        pyproject = tomllib.load(handle)
    tool_config = pyproject.get("tool", {})
    return isinstance(tool_config, dict) and "vulture" in tool_config


def scan_vulture(tmpdir: Path, *, root_dir: Path) -> dict[str, int]:
    output_path = tmpdir / "vulture.txt"
    args = ["uv", "run", "--with", "vulture==2.14", "vulture"]
    if not has_vulture_config(root_dir=root_dir):
        paths = tracked_python_paths(root_dir=root_dir)
        if not paths:
            return {"total": 0}
        args.extend(paths)
    result = run_command(args, root_dir=root_dir, stdout_path=output_path)
    if result.returncode not in {0, 3}:
        sys.stderr.write(result.stderr)
        raise SystemExit(result.returncode)
    total = sum(1 for line in output_path.read_text(encoding="utf-8").splitlines() if line.strip())
    return {"total": total}


def prepare_jscpd_tree(tmpdir: Path, *, root_dir: Path) -> Path | None:
    tracked_paths = tracked_python_paths(root_dir=root_dir)
    if not tracked_paths:
        return None

    source_dir = tmpdir / "jscpd-source"
    for relative_path in tracked_paths:
        source_path = root_dir / relative_path
        if not source_path.is_file():
            continue
        target_path = source_dir / relative_path
        target_path.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source_path, target_path)
    return source_dir


def scan_jscpd(tmpdir: Path, *, root_dir: Path) -> dict[str, int | float]:
    source_dir = prepare_jscpd_tree(tmpdir, root_dir=root_dir)
    if source_dir is None:
        return {"duplicates": 0, "duplicated_lines": 0, "percentage": 0.0}

    jscpd_dir = tmpdir / "jscpd"
    jscpd_dir.mkdir()
    result = subprocess.run(
        [
            "pnpm",
            "dlx",
            "jscpd@4.0.9",
            "--silent",
            "--min-lines",
            "10",
            "--min-tokens",
            "80",
            "--threshold",
            "100",
            "--reporters",
            "json",
            "--output",
            str(jscpd_dir),
            "--format",
            "python",
            "--pattern",
            "**/*.py",
            ".",
        ],
        cwd=source_dir,
        check=False,
        text=True,
    )
    if result.returncode != 0:
        raise SystemExit(result.returncode)
    report = json.loads((jscpd_dir / "jscpd-report.json").read_text(encoding="utf-8"))
    total = report.get("statistics", {}).get("total", {})
    return {
        "duplicates": int(total.get("clones", 0)),
        "duplicated_lines": int(total.get("duplicatedLines", 0)),
        "percentage": float(total.get("percentage", 0.0)),
    }


def collect_metrics(*, include_duplication: bool, root_dir: Path = ROOT_DIR) -> dict[str, object]:
    with tempfile.TemporaryDirectory() as tmp:
        tmpdir = Path(tmp)
        metrics = SlopMetrics(
            ruff_strict=scan_ruff(tmpdir, root_dir=root_dir),
            vulture=scan_vulture(tmpdir, root_dir=root_dir),
            jscpd=scan_jscpd(tmpdir, root_dir=root_dir) if include_duplication else None,
        )
        return metrics.to_json_dict()


def numeric_value(value: object) -> int | float | None:
    if isinstance(value, bool):
        return None
    if isinstance(value, int | float):
        return value
    return None


def ratchet_failures(baseline: dict[str, object], current: dict[str, object]) -> list[str]:
    failures: list[str] = []
    baseline_ruff = baseline["ruff_strict"]
    current_ruff = current["ruff_strict"]
    if not isinstance(baseline_ruff, dict) or not isinstance(current_ruff, dict):
        raise RuntimeError("Invalid Ruff slop-scan baseline shape.")
    baseline_ruff = cast("dict[str, object]", baseline_ruff)
    current_ruff = cast("dict[str, object]", current_ruff)

    baseline_total = numeric_value(baseline_ruff.get("total"))
    current_total = numeric_value(current_ruff.get("total"))
    if baseline_total is None or current_total is None:
        raise RuntimeError("Invalid Ruff total in slop-scan baseline.")
    if current_total > baseline_total:
        failures.append(f"ruff strict total increased: {current_total} > {baseline_total}")

    baseline_rules = baseline_ruff.get("by_rule", {})
    current_rules = current_ruff.get("by_rule", {})
    if not isinstance(baseline_rules, dict) or not isinstance(current_rules, dict):
        raise RuntimeError("Invalid Ruff by_rule slop-scan baseline shape.")
    baseline_rules = cast("dict[str, object]", baseline_rules)
    current_rules = cast("dict[str, object]", current_rules)
    for rule, count_value in sorted(current_rules.items()):
        count = numeric_value(count_value)
        allowed = numeric_value(baseline_rules.get(rule, 0))
        if count is not None and allowed is not None and count > allowed:
            failures.append(f"ruff {rule} increased: {count} > {allowed}")

    for section in ("vulture", "jscpd"):
        current_section = current.get(section)
        if current_section is None:
            continue
        baseline_section = baseline.get(section)
        if baseline_section is None:
            failures.append(f"{section} is enabled but missing from baseline")
            continue
        if not isinstance(current_section, dict) or not isinstance(baseline_section, dict):
            raise RuntimeError(f"Invalid {section} slop-scan baseline shape.")
        current_section = cast("dict[str, object]", current_section)
        baseline_section = cast("dict[str, object]", baseline_section)
        for key, value in sorted(current_section.items()):
            current_value = numeric_value(value)
            allowed = numeric_value(baseline_section.get(key))
            if current_value is not None and allowed is not None and current_value > allowed:
                failures.append(f"{section} {key} increased: {current_value} > {allowed}")

    return failures


def require_runtime_tools(*, include_duplication: bool) -> None:
    if shutil.which("uv") is None:
        raise SystemExit("uv is required to run python-slop-scan.")
    if include_duplication and shutil.which("pnpm") is None:
        raise SystemExit("pnpm is required for duplication scanning.")


def should_scan_duplication() -> bool:
    return os.getenv("PYTHON_SLOP_SCAN_DUPLICATION") == "1"


def preserve_duplication_baseline(baseline: dict[str, object], current: dict[str, object]) -> None:
    if "jscpd" in baseline and "jscpd" not in current:
        current["jscpd"] = baseline["jscpd"]


def ref_exists(ref: str) -> bool:
    result = subprocess.run(
        ["git", "rev-parse", "--verify", "--quiet", f"{ref}^{{commit}}"],
        cwd=ROOT_DIR,
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return result.returncode == 0


def default_base_ref() -> str | None:
    candidates = [os.getenv("PYTHON_SLOP_SCAN_BASE_REF")]
    if github_base := os.getenv("GITHUB_BASE_REF"):
        candidates.extend([f"origin/{github_base}", github_base])
    if github_before := os.getenv("GITHUB_EVENT_BEFORE"):
        candidates.append(github_before)
    candidates.extend(["origin/main", "main"])
    return next((ref for ref in candidates if ref and ref_exists(ref)), None)


def non_test_python_loc(root_dir: Path) -> int:
    total = 0
    for relative_path in tracked_python_paths(root_dir=root_dir):
        path = Path(relative_path)
        if "tests" in path.parts or path.name.startswith("test_"):
            continue
        total += len((root_dir / relative_path).read_text(encoding="utf-8").splitlines())
    return total


def collect_base_metrics(ref: str, *, include_duplication: bool) -> tuple[dict[str, object], int]:
    with tempfile.TemporaryDirectory() as tmp:
        worktree_path = Path(tmp) / "base"
        result = subprocess.run(
            ["git", "worktree", "add", "--detach", "--quiet", str(worktree_path), ref],
            cwd=ROOT_DIR,
            check=False,
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            sys.stderr.write(result.stderr)
            raise SystemExit(result.returncode)
        metrics = collect_metrics(include_duplication=include_duplication, root_dir=worktree_path)
        return metrics, non_test_python_loc(worktree_path)


def main() -> None:
    parser = argparse.ArgumentParser(description="Run Python maintainability ratchet checks.")
    parser.add_argument("--update-baseline", action="store_true", help="Replace the committed slop-scan baseline with current metrics.")
    parser.add_argument(
        "--base-ref",
        help="Compare against this git ref to fail only newly introduced slop. Defaults to PR base, push before SHA, or origin/main.",
    )
    args = parser.parse_args()

    baseline = json.loads(BASELINE_PATH.read_text(encoding="utf-8")) if BASELINE_PATH.exists() else {}
    include_duplication = should_scan_duplication()
    require_runtime_tools(include_duplication=include_duplication)
    current = collect_metrics(include_duplication=include_duplication)
    current_non_test_loc = non_test_python_loc(ROOT_DIR)
    if args.update_baseline:
        preserve_duplication_baseline(baseline, current)
    current_json = json.dumps(current, indent=2, sort_keys=True) + "\n"

    if args.update_baseline:
        BASELINE_PATH.write_text(current_json, encoding="utf-8")
        print(f"Updated {BASELINE_PATH.relative_to(ROOT_DIR)}")
        print(current_json, end="")
        return

    base_ref = args.base_ref or default_base_ref()
    base_result = collect_base_metrics(base_ref, include_duplication=include_duplication) if base_ref else None
    base_metrics = base_result[0] if base_result else None
    base_non_test_loc = base_result[1] if base_result else None
    baseline_failures = ratchet_failures(baseline, current)
    failures = ratchet_failures(base_metrics, current) if base_metrics else baseline_failures
    if base_non_test_loc is not None and current_non_test_loc > base_non_test_loc:
        failures.append(f"non-test Python LOC increased: {current_non_test_loc} > {base_non_test_loc}")

    print(current_json, end="")
    print(f"Non-test Python LOC: {current_non_test_loc}")
    if base_metrics:
        print(f"Compared current metrics against base ref {base_ref}.")
        print(f"Base non-test Python LOC: {base_non_test_loc}")
        baseline_gap = ratchet_failures(baseline, base_metrics)
        if baseline_gap:
            print("Committed baseline is below base-ref metrics; existing debt remains visible:")
            for failure in baseline_gap:
                print(f"- {failure}")
    if failures:
        target = f"base ref {base_ref}" if base_metrics else "committed baseline"
        print(f"Python slop-scan ratchet failed against {target}:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        raise SystemExit(1)
    print("Python slop-scan ratchet passed.")


if __name__ == "__main__":
    main()
