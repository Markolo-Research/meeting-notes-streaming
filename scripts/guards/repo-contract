#!/usr/bin/env bash
set -euo pipefail

mode="${1:-full}"
root="$(git rev-parse --show-toplevel)"
cd "$root"

failures=()

require_file() {
    local path="$1"
    if [[ ! -f "$path" ]]; then
        failures+=("missing file: $path")
    fi
}

require_symlink_target() {
    local path="$1"
    local target="$2"
    if [[ ! -L "$path" || "$(readlink "$path")" != "$target" ]]; then
        failures+=("$path must be a symlink to $target")
    fi
}

require_file "AGENTS.md"
require_symlink_target "CLAUDE.md" "AGENTS.md"
require_file "justfile"
require_file "pyproject.toml"
require_file "uv.lock"

if find . -path ./.git -prune -o -path ./server -prune -o -path ./lefthook.yml -prune -o -name lefthook.yml -print | grep -q .; then
    failures+=("nested lefthook.yml files are not allowed")
fi

if [[ "$mode" == "full" ]]; then
    just_recipes="$(just --summary)"
    for recipe in fmt fix fmt-check lint typecheck test test-fast secrets secrets-staged deps-check deps-check-fast doctor doctor-staged sync sync-if-needed check-changed check ci; do
        if [[ ! " $just_recipes " =~ [[:space:]]${recipe}[[:space:]] ]]; then
            failures+=("justfile is missing required recipe: $recipe")
        fi
    done
fi

if ((${#failures[@]})); then
    printf 'Repo contract failed:\n' >&2
    printf -- '- %s\n' "${failures[@]}" >&2
    exit 1
fi

printf 'Repo contract passed (%s)\n' "$mode"
